{
	"compilerOptions": {
		"module": "esnext",
		"target": "esnext",
		"moduleResolution": "bundler",
		"lib": [
			"ESNext",
			"DOM",
			"DOM.Iterable"
		],
		"skipLibCheck": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"jsx": "react-jsx",
		"types": [
			"node",
			"playwright",
			"vitest/globals",
			"@testing-library/jest-dom/vitest",
			"@testing-library/dom"
		]
	},
	"include": ["src/**/*", ".storybook"]
}